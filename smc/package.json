{
  "name": "flipen-smart-contract",
  "version": "1.0.0",
  "description": "Flipen coin flip smart contract optimized for MiniPay",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "coverage": "hardhat coverage",
    "node": "hardhat node",
    "deploy:localhost": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:hardhat": "hardhat run scripts/deploy.ts --network hardhat",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "deploy:celo": "hardhat run scripts/deploy.ts --network celo",
    "upgrade:localhost": "hardhat run scripts/upgrade.ts --network localhost",
    "upgrade:sepolia": "hardhat run scripts/upgrade.ts --network sepolia",
    "upgrade:celo": "hardhat run scripts/upgrade.ts --network celo",
    "interact:localhost": "hardhat run scripts/interact.ts --network localhost",
    "interact:sepolia": "hardhat run scripts/interact.ts --network sepolia",
    "interact:celo": "hardhat run scripts/interact.ts --network celo",
    "verify:sepolia": "hardhat verify --network sepolia",
    "verify:celo": "hardhat verify --network celo"
  },
  "devDependencies": {
    "@chainlink/contracts": "^1.5.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@openzeppelin/contracts": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.0.0",
    "@openzeppelin/hardhat-upgrades": "^3.9.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "chai": "^4.3.0",
    "ethers": "^6.16.0",
    "hardhat": "^2.26.0",
    "hardhat-gas-reporter": "^1.0.9",
    "mocha": "^10.0.0",
    "solidity-coverage": "^0.8.5",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^16.5.0"
  }
}
